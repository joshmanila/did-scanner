DATABASE_URL=
APP_ENCRYPTION_KEY=
CONVOSO_USE_FIXTURES=
VERCEL_CRON_SECRET=

# Optional: email alerts on sync failure. Both must be set to enable.
# Alerts are deduped to once per 30 minutes per dialer/kind.
RESEND_API_KEY=
ALERT_EMAIL_TO=

# Optional legacy fallback: one-time seeding of a "Default" dialer
# through `npm run db:seed` when the dialers table is empty.
CONVOSO_API_URL=
CONVOSO_AUTH_TOKEN=
